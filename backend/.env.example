# Google AI Studio - https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=cole_sua_chave_aqui

# Groq - https://console.groq.com/keys (usado para Whisper STT)
GROQ_API_KEY=

# Langfuse Cloud - https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Qdrant — deixe vazio para usar modo local persistente em data/qdrant_storage/
# Para Qdrant Cloud, preencha com a URL e a API key do projeto
QDRANT_URL=
QDRANT_API_KEY=

# n8n local
N8N_WEBHOOK_URL=http://localhost:5678/webhook/youvisa-evento

# Server
PORT=8000
CORS_ORIGINS=http://localhost:5173
